! !
!Teatro categoriesFor: #precarga:!public! !

"Declaracion de variables"
|teatro espectaculo1 espectaculo2 espectaculo3 espectaculo4 espectador cuenta|

"Inicializa instancia de Teatro"
teatro:=Teatro crearTeatroNom: 'Teatro UNAJ' direccion: 'Avenida calchaqui 1000' cap: 100.

teatro inspect.
teatro verEspectaculos.
"Buscar espectaculo"
espectaculos:=teatro buscarEspectaculo: 'cantante'.
espectaculos inspect.

"Crear cuenta de espectador no registrado"

"Inicializa instancia de Espectador"
espectador:=Espectador crearEspectadorNom: 'Juan' apellido: 'Perez' dni: 20202020.

"Inicializa instancia de Cuenta"
cuenta:=Cuenta crearCuenta: espectador.

"Agregar cuenta a Teatro"
teatro agregarCuenta: cuenta.
teatro agregarCuenta: (Cuenta crearCuenta: (Espectador crearEspectadorNom: 'test' apellido: 'testo' dni: 11)).
teatro agregarCuenta: (Cuenta crearCuenta: (Espectador crearEspectadorNom: 'Platon' apellido: 'Lleno' dni: 100)).
teatro agregarCuenta: (Cuenta crearCuenta: (Espectador crearEspectadorNom: 'Amadeus' apellido: 'Mozart' dni: 10021)).
teatro agregarCuenta: (Cuenta crearCuenta: (Espectador crearEspectadorNom: 'Jhony' apellido: 'Begood' dni: 1900)).
teatro agregarNCuenta: 'Pepe' apellido: 'Argento' dni: 200000.

"metodo existe cuenta de Teatro - devuelve un booleano"
bool:=teatro existeCuenta: 13311.
bool:=teatro existeCuenta: 11.
teatro verEspectaculos.
teatro inspect.
esp:=teatro buscarEspectaculo: 'standup'.
(esp at: 2) inspect.

""""t:=teatro buscarCuenta: 11.
""""t inspect.

c := teatro verCartelera.
c inspect.
teatro inspect.
(c at:'lunes') add: (espectaculo3).
(c at:'lunes') addLast: (espectaculo4).
d:= (c at: 'lunes') .

d inspect.!

