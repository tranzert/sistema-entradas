c inspect.
teatro inspect.
(c at:'lunes') add: (teatro agregarEspectaculo: (Espectaculo crearEspectaculoNom: 'espectaculo' fechaYhorario: '121212' descripcion: 'descripcion' entradasVendidas: 0 entradasTotales: 100 precioEntrada: 300 dia: 'viernes' )).
